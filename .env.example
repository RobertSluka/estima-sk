# Backend read API the browser talks to (baked in at build time).
NEXT_PUBLIC_API_URL=http://localhost:8011

# ── Admin account (server-side runtime env; see lib/auth.ts) ────────────────
# Login is DISABLED until ADMIN_PASSWORD is set — there is no built-in default
# password. AUTH_SECRET signs the session cookie; if unset it is derived from
# ADMIN_PASSWORD (set it explicitly so rotating the password doesn't log the
# admin out ... or do rotate both, that's the point of a rotation).
ADMIN_EMAIL=admin@estima.sk
ADMIN_PASSWORD=
AUTH_SECRET=
