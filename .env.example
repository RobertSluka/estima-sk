# Backend read API the browser talks to (baked in at build time).
NEXT_PUBLIC_API_URL=http://localhost:8011

# ── Admin account (server-side runtime env; see lib/auth.ts) ────────────────
# Login is DISABLED until ADMIN_PASSWORD is set — there is no built-in default
# password. AUTH_SECRET signs the session cookie; if unset it is derived from
# ADMIN_PASSWORD (set it explicitly so rotating the password doesn't log the
# admin out ... or do rotate both, that's the point of a rotation).
ADMIN_EMAIL=admin@estima.sk
ADMIN_PASSWORD=
AUTH_SECRET=

# ── User accounts (estima-sk-backend /internal API; see lib/backend.ts) ──────
# Registration + Google sign-in are DISABLED until INTERNAL_API_KEY matches the
# backend's value. BACKEND_INTERNAL_URL is how the Next.js *server* reaches the
# backend (defaults to NEXT_PUBLIC_API_URL; in Docker use the service name).
INTERNAL_API_KEY=
BACKEND_INTERNAL_URL=

# ── Google sign-in (lib/google.ts) ───────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client
# ("Web application"). Authorized redirect URI must be
#   <APP_BASE_URL>/api/auth/google/callback
# APP_BASE_URL is the public origin (needed behind a proxy; defaults to the
# request origin in dev, e.g. http://localhost:3000).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_BASE_URL=

# ── Stripe subscriptions (lib/stripe.ts) ─────────────────────────────────────
# STRIPE_PRICE_PRO is the recurring Price id of the Pro plan (9,90 €/month).
# The webhook endpoint is <APP_BASE_URL>/api/billing/webhook with events:
#   checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_WEBHOOK_SECRET=
